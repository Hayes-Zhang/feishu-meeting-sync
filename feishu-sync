#!/usr/bin/env python3
"""
feishu-meeting-sync — 飞书会议纪要同步工具
基于 @larksuite/cli 官方 CLI (v2)

https://github.com/Hayes-Zhang/feishu-meeting-sync
"""

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path
from datetime import datetime

# ─── 配置 ───

NOTES_DIR = Path(os.environ.get("FEISHU_SYNC_DIR", Path.home() / "Projects" / "meeting-notes"))
CONFIG_DIR = Path.home() / ".config" / "feishu-sync"
SYNC_RECORD = CONFIG_DIR / "synced.json"
LARK_CLI = shutil.which("lark-cli") or "lark-cli"

# ─── 基础工具 ───

def run_cli(*args):
    """调用 lark-cli 并返回解析后的 JSON data 字段"""
    cmd = [LARK_CLI] + list(args)
    # 如果没有显式指定 --format，加上 --format json
    if "--format" not in args:
        cmd += ["--format", "json"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise RuntimeError(f"lark-cli 调用失败:\n{result.stdout}{result.stderr}")
    data = json.loads(result.stdout)
    if not data.get("ok", True):
        error = data.get("error", {})
        if error.get("type") == "missing_scope":
            hint = error.get("hint", "")
            raise RuntimeError(f"权限不足: {error.get('message', '')}\n💡 {hint}")
        raise RuntimeError(f"lark-cli 错误: {json.dumps(error, ensure_ascii=False)}")
    return data.get("data", data)


def download_media(token, output_path, media_type="media"):
    """下载文档中的图片或画板。lark-cli 要求 --output 为相对路径，所以 cd 到目标目录再用文件名。"""
    output_path = Path(output_path)
    result = subprocess.run(
        [LARK_CLI, "docs", "+media-download",
         "--token", token, "--type", media_type,
         "--output", f"./{output_path.name}", "--overwrite"],
        capture_output=True, text=True,
        cwd=str(output_path.parent)
    )
    return result.returncode == 0


def is_minutes_url(url_or_id):
    return "/minutes/" in url_or_id


def extract_doc_id(url_or_id):
    if "/" in url_or_id:
        return url_or_id.rstrip("/").split("/")[-1].split("?")[0]
    return url_or_id


def safe_dirname(name):
    return re.sub(r'[/:*?"<>|]', '_', name)


def extract_meeting_time(content):
    m = re.search(r'会议时间：.*?(\d{1,2}:\d{2})\s', content)
    if m:
        return m.group(1).replace(":", "")
    return ""


def find_transcript_doc_ids(content):
    """从智能纪要 markdown 中提取文字记录的 doc_id"""
    doc_ids = []
    in_transcript = False
    for line in content.split('\n'):
        if '文字记录' in line:
            in_transcript = True
        elif re.match(r'^-\s', line) and in_transcript and 'feishu' not in line:
            in_transcript = False
        if in_transcript:
            for m in re.finditer(r'feishu\.cn/docx/([A-Za-z0-9]+)', line):
                doc_ids.append(m.group(1))
    if not doc_ids:
        doc_ids = re.findall(r'feishu\.cn/docx/([A-Za-z0-9]+)', content)
    return doc_ids


def extract_image_tokens(content):
    """从 markdown 中提取 <image token="..."> 的 token"""
    return re.findall(r'<image\s+token="([^"]+)"', content)


def extract_whiteboard_tokens(content):
    """从 markdown 中提取 <whiteboard token="..."> 的 token"""
    return re.findall(r'<whiteboard\s+token="([^"]+)"', content)

# ─── 增量同步记录 ───

def load_synced():
    # 兼容旧版 synced.json 位置
    old_record = Path.home() / ".lark" / "synced.json"
    if not SYNC_RECORD.exists() and old_record.exists():
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        shutil.copy2(old_record, SYNC_RECORD)
        print(f"📦 已迁移同步记录: {old_record} → {SYNC_RECORD}")
    if SYNC_RECORD.exists():
        with open(SYNC_RECORD) as f:
            return json.load(f)
    return {}


def save_synced(record):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(SYNC_RECORD, "w") as f:
        json.dump(record, f, ensure_ascii=False, indent=2)


def is_synced(doc_id):
    return doc_id in load_synced()


def mark_synced(doc_id, folder_name):
    record = load_synced()
    record[doc_id] = {"folder": folder_name, "synced_at": datetime.now().isoformat()}
    save_synced(record)

# ─── 文档拉取 ───

def fetch_doc(doc_id, output_dir, filename_prefix):
    """拉取飞书文档并保存为 markdown，同时下载图片"""
    data = run_cli("docs", "+fetch", "--doc", doc_id)
    title = data.get("title", "untitled")
    content = data.get("markdown", "")
    content = re.sub(r'</?table>|</?tbody>|</?tr>|</?td>', '', content)
    content = re.sub(r'\n{3,}', '\n\n', content)

    # 下载图片
    img_dir = output_dir / "images"
    image_tokens = extract_image_tokens(content)
    total_media = 0

    for token in image_tokens:
        img_dir.mkdir(parents=True, exist_ok=True)
        fname = f"img_{token}.png"
        fpath = img_dir / fname
        if download_media(token, fpath):
            content = re.sub(
                rf'<image\s+token="{re.escape(token)}"[^/]*/?>',
                f'![图片](images/{fname})',
                content
            )
            total_media += 1
            print(f"  📷 下载图片: {fname}")

    # 下载画板
    whiteboard_tokens = extract_whiteboard_tokens(content)
    for token in whiteboard_tokens:
        img_dir.mkdir(parents=True, exist_ok=True)
        fname = f"whiteboard_{token}.png"
        fpath = img_dir / fname
        if download_media(token, fpath, media_type="whiteboard"):
            content = re.sub(
                rf'<whiteboard\s+token="{re.escape(token)}"[^/]*/?>',
                f'![画板](images/{fname})',
                content
            )
            total_media += 1
            print(f"  🎨 下载画板: {fname}")

    md_path = output_dir / f"{filename_prefix}.md"
    md_path.write_text(content, encoding="utf-8")
    return title, str(md_path), total_media, content

# ─── 会议同步 ───

def make_folder_name(title, content):
    date_match = re.search(r'(\d{4})年(\d{1,2})月(\d{1,2})日', title)
    if date_match:
        y, m, d = date_match.groups()
        date_str = f"{y}-{int(m):02d}-{int(d):02d}"
    else:
        date_str = "unknown"

    topic = re.sub(r'^(智能纪要|文字记录)[：:]?\s*', '', title)
    topic = re.sub(r'\s*\d{4}年\d{1,2}月\d{1,2}日\s*$', '', topic).strip()
    if not topic:
        topic = "未命名"

    base_name = f"{date_str} {topic}"

    candidate = NOTES_DIR / safe_dirname(base_name)
    if candidate.exists():
        time_str = extract_meeting_time(content)
        if time_str:
            base_name = f"{date_str} {topic} {time_str}"

    return safe_dirname(base_name)


def sync_minutes(minute_token, force=False):
    """同步妙记录音（/minutes/ 链接）"""
    if not force and is_synced(minute_token):
        record = load_synced()[minute_token]
        print(f"⏭️  已同步过: {record['folder']}（用 --force 强制重新同步）")
        return

    NOTES_DIR.mkdir(parents=True, exist_ok=True)

    meta = run_cli("minutes", "minutes", "get",
                    "--params", json.dumps({"minute_token": minute_token}))
    minute = meta.get("minute", meta)
    title = minute.get("title", "untitled")
    create_time = minute.get("create_time", "")
    duration = minute.get("duration", "")

    date_str = "unknown"
    if create_time:
        try:
            ts = int(create_time)
            dt = datetime.fromtimestamp(ts)
            date_str = dt.strftime("%Y-%m-%d")
            create_time = dt.isoformat()
        except (ValueError, TypeError):
            try:
                dt = datetime.fromisoformat(create_time)
                date_str = dt.strftime("%Y-%m-%d")
            except Exception:
                pass

    folder_name = safe_dirname(f"{date_str} {title}")
    meeting_dir = NOTES_DIR / folder_name
    meeting_dir.mkdir(parents=True, exist_ok=True)

    print(f"📁 {folder_name}")

    summary_path = meeting_dir / f"{folder_name} 摘要.md"
    summary_lines = [
        f"# {title}\n",
        f"- **日期**: {create_time}",
        f"- **时长**: {duration}",
        f"- **来源**: 飞书妙记录音",
    ]
    summary_path.write_text("\n".join(summary_lines), encoding="utf-8")

    mark_synced(minute_token, folder_name)
    print(f"✅ {title}（妙记录音）")


def sync_meeting(url_or_id, force=False):
    """同步一次会议（自动识别文档/妙记）"""
    if is_minutes_url(url_or_id):
        minute_token = extract_doc_id(url_or_id)
        return sync_minutes(minute_token, force=force)

    doc_id = extract_doc_id(url_or_id)

    if not force and is_synced(doc_id):
        record = load_synced()[doc_id]
        print(f"⏭️  已同步过: {record['folder']}（用 --force 强制重新同步）")
        return

    NOTES_DIR.mkdir(parents=True, exist_ok=True)

    # 先拉一次获取标题和内容用于确定文件夹名
    data = run_cli("docs", "+fetch", "--doc", doc_id)
    title = data.get("title", "untitled")
    content = data.get("markdown", "")

    folder_name = make_folder_name(title, content)
    meeting_dir = NOTES_DIR / folder_name
    meeting_dir.mkdir(parents=True, exist_ok=True)

    print(f"📁 {folder_name}")

    t1, p1, m1, content = fetch_doc(doc_id, meeting_dir, f"{folder_name} 智能纪要")
    media_info = f"（含 {m1} 个媒体文件）" if m1 > 0 else ""
    print(f"✅ {t1}{media_info}")
    mark_synced(doc_id, folder_name)

    # 自动拉取关联的文字记录
    transcript_ids = find_transcript_doc_ids(content)
    for tid in transcript_ids:
        if tid == doc_id:
            continue
        try:
            check_data = run_cli("docs", "+fetch", "--doc", tid)
            check_title = check_data.get("title", "")
            if "文字记录" not in check_title:
                continue
            print(f"🔗 拉取文字记录...")
            t2, p2, m2, _ = fetch_doc(tid, meeting_dir, f"{folder_name} 文字记录")
            print(f"✅ {t2}")
            mark_synced(tid, folder_name)
        except Exception as e:
            print(f"⚠️ 文字记录拉取失败: {e}")

# ─── 搜索发现 ───

def search_meetings(query):
    data = run_cli("docs", "+search", "--query", query)
    results = data.get("results", data.get("items", []))
    meetings = []
    seen = set()
    for item in results:
        # 官方 CLI 搜索结果：title 在 title_highlighted，token 在 result_meta.token
        title_raw = item.get("title_highlighted", item.get("title", ""))
        title = re.sub(r'</?h>', '', title_raw)  # 去掉高亮标签
        meta = item.get("result_meta", {})
        token = meta.get("token", item.get("obj_token", item.get("token", "")))
        if "智能纪要" in title and token not in seen:
            seen.add(token)
            meetings.append({"token": token, "title": title})
    return meetings


def search_and_sync(query, force=False):
    print(f"🔍 搜索: {query}")
    meetings = search_meetings(query)

    if not meetings:
        print("未找到匹配的智能纪要")
        print("💡 提示：如果是妙记录音（非智能纪要文档），请直接给 /minutes/ 链接同步")
        return

    print(f"找到 {len(meetings)} 个智能纪要:\n")
    for i, m in enumerate(meetings):
        synced = "✅已同步" if is_synced(m["token"]) else "⬜未同步"
        print(f"  [{i+1}] {m['title']}  {synced}")
    print()

    synced_count = 0
    for m in meetings:
        if not force and is_synced(m["token"]):
            continue
        print(f"\n🔄 同步: {m['title']}")
        try:
            sync_meeting(m["token"], force=force)
            synced_count += 1
        except Exception as e:
            print(f"❌ 失败: {e}")

    if synced_count == 0:
        print("所有会议已同步，无需操作")
    else:
        print(f"\n🎉 本次同步 {synced_count} 个会议")

# ─── CLI ───

def main():
    args = sys.argv[1:]

    if not args or args == ["--help"] or args == ["-h"]:
        print("feishu-meeting-sync — 飞书会议纪要同步工具 (v2: @larksuite/cli)")
        print()
        print("前置条件:")
        print("  npm install -g @larksuite/cli")
        print("  lark-cli config init --new")
        print("  lark-cli auth login --recommend")
        print()
        print("用法:")
        print("  feishu-sync <URL或doc_id> [更多...]       同步指定会议（支持 /docx/ 和 /minutes/ 链接）")
        print("  feishu-sync --search <关键词>            搜索并同步")
        print("  feishu-sync --today                      同步今天的会议")
        print("  feishu-sync --recent                     同步最近的会议")
        print("  feishu-sync --force <...>                强制重新同步")
        print("  feishu-sync --list                       列出已同步的会议")
        print()
        print("环境变量:")
        print(f"  FEISHU_SYNC_DIR    输出目录（默认: ~/Projects/meeting-notes）")
        sys.exit(0)

    force = "--force" in args
    if force:
        args.remove("--force")

    if args[0] == "--search":
        query = " ".join(args[1:]) if len(args) > 1 else "智能纪要"
        search_and_sync(query, force=force)
    elif args[0] == "--today":
        today = datetime.now()
        query = f"智能纪要 {today.year}年{today.month}月{today.day}日"
        search_and_sync(query, force=force)
    elif args[0] == "--recent":
        search_and_sync("智能纪要", force=force)
    elif args[0] == "--list":
        record = load_synced()
        if not record:
            print("还没有同步过任何会议")
        else:
            folders = sorted(set(v["folder"] for v in record.values()))
            print(f"已同步 {len(folders)} 个会议:\n")
            for f in folders:
                print(f"  📁 {f}")
    else:
        for url in args:
            print(f"\n🔄 同步: {url}")
            try:
                sync_meeting(url, force=force)
            except Exception as e:
                print(f"❌ 失败: {e}")

if __name__ == "__main__":
    main()
